      "summary_zh": "\u7f8e\u80a1\u65bc4\u670829\u65e5\u5e7e\u4e4e\u539f\u5730\u8e0f\u6b65\uff0c\u6a19\u666e500\u8207\u7d0d\u65af\u9054\u514b\u96d9\u96d9\u6536\u5e73\uff0c\u5e02\u5834\u5728\u7b49\u5f85\u91cd\u8981\u7d93\u6fdf\u6578\u64da\u8207\u6d88\u5316\u5bc6\u96c6\u8ca1\u5831\u5b63\u7684\u540c\u6642\u9677\u5165\u89c0\u671b\u3002\u9019\u7a2e\u4f4e\u6ce2\u52d5\u3001\u7f3a\u4e4f\u65b9\u5411\u7684\u76e4\u9762\u5728\u8ca1\u5831\u5b63\u4e2d\u6bb5\u5341\u5206\u5e38\u898b\uff0c\u6295\u8cc7\u8005\u4e0d\u9858\u5728\u95dc\u9375\u5831\u544a\u516c\u4f48\u524d\u8f15\u6613\u5efa\u7acb\u5927\u5009\u4f4d\u3002\u7136\u800c\u6307\u6578\u8868\u9762\u5e73\u975c\u4e4b\u4e0b\uff0c\u500b\u80a1\u52d5\u80fd\u80a1\u6301\u7e8c\u5c55\u73fe\u76f8\u5c0d\u5f37\u52e2\uff0c\u986f\u793a\u672c\u9031\u5e02\u5834\u52d5\u529b\u4f86\u81ea\u677f\u584a\u8f2a\u52d5\uff0c\u800c\u975e\u6307\u6578\u7684\u6574\u9ad4\u4e0a\u6f32\u3002",
      "sources": []
