      "summary_zh": "\u7f8e\u80a1\u65bc4\u670830\u65e5\u5e7e\u4e4e\u5e73\u76e4\u6536\u5e02\uff0c\u90a3\u65af\u9054\u514b\u8207\u6a19\u666e500\u6307\u6578\u5747\u672a\u51fa\u73fe\u660e\u986f\u6ce2\u52d5\u3002\u6b64\u7a2e\u6a6b\u76e4\u8d70\u52e2\u53cd\u6620\u51fa\u6a5f\u69cb\u6295\u8cc7\u8005\u5728\u6708\u672b\u9032\u884c\u6295\u8cc7\u7d44\u5408\u518d\u5e73\u8861\u6642\u7684\u5be9\u614e\u614b\u5ea6\uff0c\u52a0\u4e0a5\u6708\u4efd\u6b77\u4f86\u8207\u300c\u4e94\u6708\u8ce3\u80a1\u96e2\u5834\u300d\u7684\u5b63\u7bc0\u6027\u898f\u5f8b\u76f8\u95dc\uff0c\u5e02\u5834\u89c0\u671b\u60c5\u7dd2\u5347\u6eab\u3002\u5728\u7f3a\u4e4f\u806f\u6e96\u6703\u5b98\u54e1\u767c\u8a00\u6216\u91cd\u5927\u8ca1\u5831\u610f\u5916\u7b49\u65b0\u50ac\u5316\u5291\u7684\u60c5\u6cc1\u4e0b\uff0c\u6295\u8cc7\u8005\u5927\u591a\u6309\u5175\u4e0d\u52d5\u3002",
